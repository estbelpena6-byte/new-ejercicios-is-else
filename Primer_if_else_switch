        static void Tipo_de_triángulo()
        {
            Console.Clear();

            Console.WriteLine("Escribe el primer número:");
            int n1 = int.Parse(Console.ReadLine());

            Console.WriteLine("Escribe el segundo número:");
            int n2 = int.Parse(Console.ReadLine());

            Console.WriteLine("Escribe el tercer número:");
            int n3 = int.Parse(Console.ReadLine());

            
            if ((n1 + n2 > n3) && (n1 + n3 > n2) && (n2 + n3 > n1))
            {
                Console.WriteLine("¡Sí se puede formar un triángulo!");

                
                if (n1 == n2 && n2 == n3)
                {
                    Console.WriteLine("El triángulo es Equilátero (todos los lados son iguales).");
                }
                else if (n1 == n2 || n1 == n3 || n2 == n3)
                {
                    Console.WriteLine("El triángulo es Isósceles (tiene dos lados iguales).");
                }
                else
                {
                    Console.WriteLine("El triángulo es Escaleno (todos los lados son diferentes).");
                }
            }
            else
            {
                Console.WriteLine("No se puede formar un triángulo con esas longitudes.");
            }


            Console.WriteLine("\nPresione ENTER para volver al menú...");
            Console.ReadLine();
        }
