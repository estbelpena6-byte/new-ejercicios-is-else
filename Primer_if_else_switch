        static void Clasificación_de_IMC()
        {
            Console.Clear();

            Console.WriteLine("Agrega tu peso en KG");
            double Peso = double.Parse(Console.ReadLine());

            Console.WriteLine("Agrega tu altura en Metro");
            double altura = double.Parse(Console.ReadLine());

            double IMC = 0;

            IMC =  Peso / (altura * altura);


            Console.WriteLine("========= Respuesta ===========");
            Console.WriteLine($"Tu IMC es: {IMC:F2}");

            if (IMC < 18.5)
            {
                Console.WriteLine("Bajo Peso");
            }
            else if (IMC >= 18.5 && IMC <= 24.9)
            {
                Console.WriteLine("Peso Normal");
            }
            else if (IMC >= 25 && IMC <= 29.9)
            {
                Console.WriteLine("Sobrepeso");
            }
            else if (IMC >= 30)
            {
                Console.WriteLine("Obesidad");
            }
            Console.WriteLine("\nPresione ENTER para volver al menú...");
            Console.ReadLine();
        }
